managed implementation in class /apl02/i_giftcard unique;
strict ( 2 );
with draft;

define behavior for /APL02/I_GIFTCARD alias GiftCard
persistent table /apl02/giftcard
draft table /apl02/giftcard_d
lock master total etag LocalLastChanged
etag master LastChanged
{
  create;
  update;
  delete;

  draft action Edit;
  draft action Activate optimized;
  draft action Discard;
  draft action Resume;
  draft determine action Prepare;

  field ( numbering : managed, readonly ) SapUUID;
  field ( readonly ) LocalLastChanged, LastChanged;
  field ( mandatory ) Giftcardnumber, SapDescription;

  mapping for /apl02/giftcard
  {
    SapUUID          = sap_uuid;
    Giftcardnumber   = giftcardnumber;
    SapDescription   = sap_description;
    AmountV          = amount_v;
    AmountC          = amount_c;
    LocalLastChanged = local_last_changed;
    LastChanged      = last_changed;
  }
}
